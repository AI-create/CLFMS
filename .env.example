# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=CLFMS

# Set DEBUG=false in production
DEBUG=false

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong secret before deploying.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

ALGORITHM=HS256

# Token lifetime in minutes (480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./clfms.db

# ─── Admin Seed Account ───────────────────────────────────────────────────────
# REQUIRED: Change before first deployment
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-me-strong-password-min-12-chars
ADMIN_ROLE=admin

# ─── GST Rates ────────────────────────────────────────────────────────────────
COMPANY_STATE=KA
GST_CGST_RATE=0.09
GST_SGST_RATE=0.09
GST_IGST_RATE=0.18

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave blank to use the built-in dev defaults (localhost:5173 + localhost:8000).
# In production, set this to your actual domain(s).
# CORS_ORIGINS=https://app.yourcompany.com
